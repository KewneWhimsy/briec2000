---
// src/components/optimize_image.astro
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// Import automatique de toutes les images du projet
const images = import.meta.glob('../assets/**/*.{png,jpg,jpeg,webp,avif,gif}', { 
  eager: true,
  import: 'default'
}) as Record<string, ImageMetadata>;

// Créer le mapping avec les chemins absolus
const imageMap: Record<string, ImageMetadata> = {};
for (const [path, image] of Object.entries(images)) {
  const absolutePath = path.replace('../', '/src/');
  imageMap[absolutePath] = image;
}

// Props du composant
export interface Props {
  src: ImageMetadata | string;
  alt: string;
  widths?: number[];
  sizes?: string;
  class?: string;
  loading?: "eager" | "lazy";
  withBg?: boolean;
  [key: string]: any;
}

const {
  src,
  alt,
  widths = [400, 800, 1200],
  sizes = "(max-width: 767px) 100vw, 800px",
  class: className = "w-full h-auto",
  loading = "lazy",
  withBg = false,
  ...props
} = Astro.props;

// Vérification de sécurité pour src - retourner null au lieu de lancer une erreur
if (!src) {
  return null;
}

// Récupérer l'image optimisée ou utiliser le src tel quel si non trouvé
const imageSrc = typeof src === 'string' ? (imageMap[src] || src) : src;

const finalClassName = withBg ? `${className || ''} special-image-with-bg`.trim() : (className || '');
---

<Picture 
  src={imageSrc} 
  alt={alt}
  widths={widths}
  sizes={sizes}
  formats={['avif', 'webp']}
  class={finalClassName}
  loading={loading}
  {...props}
/>