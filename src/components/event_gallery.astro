---
// src/components/event_gallery.astro

import { loadEventGallery } from '../utils/gallery';
import type { EventEntry } from '../../types';
import OptimizeImage from './optimize_image.astro';

export interface Props {
  event: EventEntry;
  maxThumbnails?: number;
}

const {
  event,
  maxThumbnails = 3
} = Astro.props;

const gallery = await loadEventGallery(event.id, event);

if (!gallery || !gallery.photos || gallery.photos.length === 0) {
  return null;
}

const validPhotos = gallery.photos.filter(photo => photo && photo.src);

if (validPhotos.length === 0) {
  return null;
}

const thumbnails = validPhotos.slice(0, maxThumbnails);
---

{gallery && validPhotos.length > 0 && (
  <section class="event-gallery my-8 mx-2">

    <!-- Miniatures déclencheurs -->
    <div class="flex gap-3 overflow-x-auto pb-4">
      {thumbnails.map((photo, index) => (
        photo.src && (
          <div class="flex-none w-32">
            <button
              class="gallery-trigger my-2 w-full h-32 block cursor-pointer hover:opacity-80 transition-opacity rounded-lg overflow-hidden bg-(--color-primary)/5"
              data-gallery-id={event.id}
              data-start-index={index}
              aria-label={`Voir la galerie de ${event.data.title}, photo ${index + 1}`}
            >
              <OptimizeImage
                src={photo.src}
                alt={photo.alt || `Photo ${index + 1}`}
                class="w-full h-full object-cover"
                widths={[128, 256]}
                sizes="256px"
                loading="lazy"
                transition:persist={`gallery-thumb-${event.id}-${index}`}
              />
            </button>
          </div>
        )
      ))}

      {validPhotos.length > maxThumbnails && (
        <div class="flex-none w-32">
          <button
            class="gallery-trigger my-2 w-full h-32 flex items-center justify-center text-sm opacity-60 border border-dashed border-(--color-border) rounded-lg cursor-pointer hover:opacity-80 hover:border-(--color-primary) transition-all bg-(--color-primary)/5"
            data-gallery-id={event.id}
            data-start-index={maxThumbnails}
            aria-label={`Voir toute la galerie de ${event.data.title} (${validPhotos.length} photos)`}
          >
            +{validPhotos.length - maxThumbnails} photo{validPhotos.length - maxThumbnails > 1 ? 's' : ''}
          </button>
        </div>
      )}
    </div>

    <!-- Modal galerie -->
    <div
      id={`gallery-modal-${event.id}`}
      class="gallery-modal rounded-xl border border-(--color-border) overflow-hidden max-w-[95vw] max-h-[95vh]"
      popover
      tabindex="-1"
    >
      <!-- Header -->
      <div class="bg-(--color-secondary) text-white p-3 flex justify-between items-center">
        <div>
          <h3 class="font-medium" style="color: white;">
            {gallery.event.data.gallery?.title || gallery.event.data.title}
          </h3>
          <p class="text-sm opacity-90">Photos de {gallery.photographer}</p>
        </div>
        <button
          class="w-7 h-7 bg-white/20 hover:bg-white/30 rounded-full flex items-center justify-center transition-colors"
          popovertarget={`gallery-modal-${event.id}`}
          aria-label="Fermer"
        >
          <svg width="12" height="12" viewBox="0 0 12 12" fill="currentColor">
            <path d="M1 1L11 11M11 1L1 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>

      <!-- Zone image -->
      <div class="gallery-viewer bg-black relative min-h-[70vh] touch-pan-x">

        <!-- Slides : une par photo, OptimizeImage direct -->
        {validPhotos.map((photo, index) => (
          photo.src && (
            <div
              class={`gallery-slide absolute inset-0 flex items-center justify-center${index > 0 ? ' hidden' : ''}`}
              data-slide={index}
            >
              <OptimizeImage
                src={photo.src}
                alt={photo.alt || `Photo ${index + 1}`}
                class="gallery-main-image"
                widths={[800, 1200]}
                sizes="(max-width: 767px) 90vw, 1200px"
                loading="lazy"
              />
            </div>
          )
        ))}

        <!-- Navigation gauche -->
        <button
          id={`gallery-prev-${event.id}`}
          class="gallery-nav-zone absolute left-0 top-0 w-1/12 h-full z-10 opacity-0 flex items-center justify-start pl-4 md:opacity-100 md:w-10 md:h-10 md:left-4 md:top-1/2 md:-translate-y-1/2 md:justify-center md:pl-0 md:rounded-full hover:opacity-80 disabled:opacity-40 disabled:cursor-not-allowed"
          style="background-color: transparent; color: white; border: none;"
          aria-label="Image précédente"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>

        <!-- Navigation droite -->
        <button
          id={`gallery-next-${event.id}`}
          class="gallery-nav-zone absolute right-0 top-0 w-1/12 h-full z-10 opacity-0 flex items-center justify-end pr-4 md:opacity-100 md:w-10 md:h-10 md:right-4 md:top-1/2 md:-translate-y-1/2 md:justify-center md:pr-0 md:rounded-full hover:opacity-80 disabled:opacity-40 disabled:cursor-not-allowed"
          style="background-color: transparent; color: white; border: none;"
          aria-label="Image suivante"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>

      <!-- Barre de miniatures -->
      <div class="p-3 bg-(--bg-color) border-t border-(--color-border)">
        <div class="flex gap-2 overflow-x-auto pb-2">
          {validPhotos.map((photo, index) => (
            photo.src && (
              <button
                class="gallery-thumb flex-none w-16 h-12 rounded overflow-hidden border-2 border-transparent hover:border-(--color-primary) transition-colors"
                data-index={index}
                aria-label={`Voir photo ${index + 1}`}
              >
                <OptimizeImage
                  src={photo.src}
                  alt={photo.alt || `Photo ${index + 1}`}
                  class="w-full h-full object-cover"
                  widths={[64, 128]}
                  sizes="64px"
                  loading="lazy"
                />
              </button>
            )
          ))}
        </div>
      </div>
    </div>
  </section>
)}

<style>
  .gallery-main-image {
    max-width: 100vw;
    max-height: 70vh;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  .gallery-modal {
    position: fixed;
    top: 25%;
    left: 50%;
    transform: translate(-50%, -25%) scale(0.8);
    margin: 0;
    opacity: 0;
    transition:
      display 0.3s allow-discrete,
      opacity 0.3s ease,
      transform 0.3s ease;
    transition-behavior: allow-discrete;
  }

  .gallery-modal:popover-open {
    opacity: 1;
    transform: translate(-50%, -25%) scale(1);

    @starting-style {
      opacity: 0;
      transform: translate(-50%, -25%) scale(0.8);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .gallery-modal {
      transition: display 0.3s allow-discrete, opacity 0.3s ease;
      transform: translate(-50%, -25%) scale(1);
    }

    .gallery-modal:popover-open {
      transform: translate(-50%, -25%) scale(1);
    }
  }

  .gallery-thumb.active {
    border-color: var(--color-primary);
    border-width: 4px;
  }

  .gallery-nav-zone {
    border: none;
    cursor: pointer;
  }

  @media (min-width: 768px) {
    .gallery-nav-zone {
      background-color: var(--color-secondary) !important;
    }
  }

  @media (max-width: 767px) {
    .gallery-nav-zone:disabled {
      display: none;
    }
  }

  .gallery-nav-zone:active {
    background-color: rgba(255, 255, 255, 0.1);
  }

  /* Slides proches : préchargées par le browser mais invisibles */
  .gallery-slide.slide-inactive {
    visibility: hidden;
    pointer-events: none;
  }

  .gallery-viewer {
    -webkit-touch-callout: none;
    -webkit-user-select: none;
    user-select: none;
  }
</style>

<script>
  function initEventGalleries() {
    // On boucle sur les modaux (pas les triggers) pour éviter les listeners dupliqués
    document.querySelectorAll('.gallery-modal[id^="gallery-modal-"]').forEach(modal => {
      if ((modal as HTMLElement).dataset.initialized) return;
      (modal as HTMLElement).dataset.initialized = 'true';

      const galleryId = modal.id.replace('gallery-modal-', '');
      const prevBtn = document.getElementById(`gallery-prev-${galleryId}`) as HTMLButtonElement;
      const nextBtn = document.getElementById(`gallery-next-${galleryId}`) as HTMLButtonElement;
      const galleryViewer = modal.querySelector('.gallery-viewer');
      const slides = Array.from(modal.querySelectorAll('.gallery-slide')) as HTMLElement[];
      const thumbs = Array.from(modal.querySelectorAll('.gallery-thumb'));

      if (!prevBtn || !nextBtn || !galleryViewer || !slides.length) return;

      let currentIndex = 0;

      function updateDisplay() {
        slides.forEach((slide, i) => {
          const diff = Math.abs(i - currentIndex);
          if (i === currentIndex) {
            slide.classList.remove('hidden', 'slide-inactive');
          } else if (diff <= 2) {
            slide.classList.remove('hidden');
            slide.classList.add('slide-inactive');
          } else {
            slide.classList.add('hidden');
            slide.classList.remove('slide-inactive');
          }
        });

        prevBtn.disabled = currentIndex === 0;
        nextBtn.disabled = currentIndex === slides.length - 1;

        thumbs.forEach((thumb, i) => thumb.classList.toggle('active', i === currentIndex));

        // Scroll automatique barre miniatures
        const activeThumbnail = thumbs[currentIndex] as HTMLElement | undefined;
        if (activeThumbnail) {
          const container = modal.querySelector('.flex.gap-2.overflow-x-auto');
          if (container) {
            const scrollLeft = activeThumbnail.offsetLeft - (container.clientWidth / 2) + (activeThumbnail.offsetWidth / 2);
            container.scrollTo({ left: Math.max(0, scrollLeft), behavior: 'smooth' });
          }
        }
      }

      function goToPrev() {
        if (currentIndex > 0) { currentIndex--; updateDisplay(); }
      }

      function goToNext() {
        if (currentIndex < slides.length - 1) { currentIndex++; updateDisplay(); }
      }

      // Triggers (miniatures + "+X photos") → ouvrir le modal
      document.querySelectorAll(`[data-gallery-id="${galleryId}"]`).forEach(trigger => {
        trigger.addEventListener('click', (e) => {
          e.preventDefault();
          currentIndex = parseInt(trigger.getAttribute('data-start-index') || '0');
          updateDisplay();
          (modal as any).showPopover();
          setTimeout(() => (modal as HTMLElement).focus(), 100);
        });
      });

      prevBtn.addEventListener('click', goToPrev);
      nextBtn.addEventListener('click', goToNext);

      thumbs.forEach((thumb, index) => {
        thumb.addEventListener('click', () => { currentIndex = index; updateDisplay(); });
      });

      (modal as HTMLElement).addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'ArrowLeft') { e.preventDefault(); goToPrev(); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); goToNext(); }
      });

      let startX = 0;
      galleryViewer.addEventListener('touchstart', (e) => {
        startX = (e as TouchEvent).touches[0].clientX;
      }, { passive: true });
      galleryViewer.addEventListener('touchend', (e) => {
        const deltaX = (e as TouchEvent).changedTouches[0].clientX - startX;
        if (Math.abs(deltaX) > 50) { deltaX > 0 ? goToPrev() : goToNext(); }
      }, { passive: true });
    });
  }

  document.addEventListener('astro:page-load', initEventGalleries);

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEventGalleries);
  } else {
    initEventGalleries();
  }
</script>
