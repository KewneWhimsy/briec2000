---
export const prerender = false;
import { Font } from 'astro:assets';

function mdToHtml(md: string): string {
  if (!md) return '';
  const esc = (s: string) => s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  const inline = (s: string) => esc(s)
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    .replace(/\*([^*\n]+)\*/g, '<em>$1</em>')
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2">$1</a>');
  const lines = md.split('\n');
  let html = '', para: string[] = [], list: string[] = [];
  const fp = () => { if (para.length) { html += `<p>${inline(para.join(' '))}</p>`; para = []; } };
  const fl = () => { if (list.length) { html += '<ul>' + list.map(i=>`<li>${inline(i)}</li>`).join('') + '</ul>'; list = []; } };
  for (const line of lines) {
    if (!line.trim())                 { fp(); fl(); }
    else if (line.startsWith('### ')) { fp(); fl(); html += `<h3>${inline(line.slice(4))}</h3>`; }
    else if (line.startsWith('## '))  { fp(); fl(); html += `<h2>${inline(line.slice(3))}</h2>`; }
    else if (line.match(/^[-*] /))    { fp(); list.push(line.slice(2)); }
    else                              { fl(); para.push(line); }
  }
  fp(); fl();
  return html;
}

const isPost = Astro.request.method === 'POST';
let bodyHtml = `<p style="color:#9ca3af;font-style:italic;padding:2rem;text-align:center">Remplissez le formulaire pour voir l'aperçu.</p>`;

if (isPost) {
  const form     = await Astro.request.formData();
  const title    = (form.get('title')    as string ?? '').trim();
  const date     = (form.get('date')     as string ?? '').trim();
  const time     = (form.get('time')     as string ?? '').trim();
  const location = (form.get('location') as string ?? '').trim();
  const image    = (form.get('image')    as string ?? '').trim();
  const content  = (form.get('content')  as string ?? '').trim();
  const draft    = form.get('draft') === 'on';
  const names    = form.getAll('price_name')   as string[];
  const amounts  = form.getAll('price_amount') as string[];
  const prices   = names.map((n, i) => ({ name: n.trim(), amount: parseFloat(amounts[i] ?? '0') })).filter(p => p.name);

  if (title || content) {
    const dateStr = date ? new Date(date + 'T12:00:00').toLocaleDateString('fr-FR', {
      weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
    }) : '';
    const { getGithubOwner, getGithubRepo } = await import('../../../lib/env');
    const imageFile = form.get('image_file') as File | null;
    let imgUrl = '';
    if (imageFile && imageFile.size > 0) {
      const bytes = new Uint8Array(await imageFile.arrayBuffer());
      let binary = '';
      for (let i = 0; i < bytes.byteLength; i++) binary += String.fromCharCode(bytes[i]);
      imgUrl = `data:${imageFile.type};base64,${btoa(binary)}`;
    } else if (image) {
      imgUrl = `https://raw.githubusercontent.com/${getGithubOwner()}/${getGithubRepo()}/master${image}`;
    }

    bodyHtml = `
      ${draft ? '<span class="draft-badge">Brouillon</span>' : ''}
      <header>
        <h1>${title || 'Titre'}</h1>
        ${dateStr  ? `<p class="text-lg"><time>${dateStr}</time></p>` : ''}
        ${location ? `<p><strong>Lieu :</strong> ${location}</p>` : ''}
        ${time     ? `<p><strong>Horaires :</strong> ${time}</p>` : ''}
      </header>
      ${imgUrl ? `<div class="my-8"><img src="${imgUrl}" alt="${title}" class="event-img" onerror="this.style.display='none'"></div>` : ''}
      ${prices.length ? `<div class="card prices-card"><h2>Tarifs</h2><ul class="prices-list">${prices.map(p=>`<li>${p.name}${p.amount>0?` : ${p.amount}€`:p.amount===0?' : Gratuit':''}</li>`).join('')}</ul></div>` : ''}
      <div class="event-content prose">${mdToHtml(content)}</div>`;
  }
}
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <Font cssVariable="--font-andika" />
  <Font cssVariable="--font-champ" />
  <Font cssVariable="--font-start" />
  <style is:global>
    :root {
      --color-primary: #a57fbb;
      --bg-color: #33263e;
      --text-color: #e9dff2;
      --color-border: #483759;
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: var(--font-andika), sans-serif;
      font-size: 1rem;
      line-height: 1.5;
      background-color: var(--bg-color);
      color: var(--text-color);
      padding: 1.5rem;
    }
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-champ), serif;
      color: var(--color-primary);
      font-weight: 700;
      line-height: 1.2;
    }
    h1 { font-family: var(--font-start), monospace; font-size: 2rem; margin-bottom: 1rem; }
    h2 { font-size: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--color-border); margin-top: 2rem; margin-bottom: 1rem; }
    h3 { font-size: 1.25rem; margin-top: 1.5rem; margin-bottom: 0.75rem; }
    a  { color: var(--color-primary); text-decoration: underline; }
    strong { font-weight: 600; }
    em { font-style: italic; }

    header p { margin-bottom: 0.5rem; }
    .text-lg  { font-size: 1.125rem; }

    .my-8 { margin: 2rem 0; }
    .event-img { max-width: 100%; max-height: 500px; border-radius: 0.5rem; object-fit: cover; display: block; }

    .card {
      border: 1px solid var(--color-border);
      border-radius: 0.375rem;
      box-shadow: 0 2px 4px rgba(0,0,0,.05);
    }
    .prices-card { display: inline-block; margin-bottom: 2rem; padding: 1rem; }
    .prices-card h2 { font-size: 1.25rem; margin-top: 0; border: none; }
    .prices-list { list-style: disc; margin-left: 1.5rem; line-height: 1.625; }

    .event-content h2 { font-size: 1.5rem; margin-top: 2rem; margin-bottom: 1rem; border-bottom: 1px solid var(--color-border); padding-bottom: 0.5rem; }
    .event-content h3 { font-size: 1.25rem; margin-top: 1.5rem; margin-bottom: 0.75rem; }
    .event-content p  { margin-bottom: 1rem; }
    .event-content ul { margin-left: 1.5rem; margin-bottom: 1.5rem; list-style-type: disc; }
    .event-content li { margin-bottom: 0.5rem; }

    .draft-badge {
      display: inline-block;
      background: #854d0e;
      color: #fef9c3;
      font-size: .75rem;
      padding: .15rem .6rem;
      border-radius: 999px;
      margin-bottom: .75rem;
    }
  </style>
</head>
<body>
  <article class="max-w-3xl" set:html={bodyHtml}></article>
</body>
</html>
