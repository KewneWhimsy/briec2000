---
export const prerender = false;
import AdminLayout from "../../layouts/admin-layout.astro";
import { getGithubToken } from '../../lib/env';
import { listEvents, getEvent } from '../../lib/github';
import { parseFrontmatter } from '../../lib/markdown';

const token = getGithubToken();
const notice = Astro.url.searchParams.get('notice');
const errorParam = Astro.url.searchParams.get('error');

interface EventRow {
  slug: string; title: string; date: string; draft: boolean; past: boolean;
}

let events: EventRow[] = [];
let loadError = '';

try {
  const files = await listEvents(token);
  const today = new Date().toISOString().split('T')[0];

  events = (await Promise.all(files.map(async f => {
    const slug = f.name.replace(/\.md$/, '');
    try {
      const { content } = await getEvent(token, slug);
      const { data } = parseFrontmatter(content);
      return { slug, title: data.title ?? slug, date: data.date ?? '', draft: !!data.draft, past: (data.date ?? '') < today };
    } catch {
      return { slug, title: slug, date: '', draft: false, past: false };
    }
  }))).sort((a, b) => b.date.localeCompare(a.date));
} catch (e) {
  loadError = String(e);
}

const fmt = (d: string) => { const [y,m,j] = d.split('-'); return d ? `${j}/${m}/${y}` : '—'; };
---
<AdminLayout title="Événements">
  {notice && (
    <div class="mb-4 bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg text-sm">{notice}</div>
  )}
  {(errorParam || loadError) && (
    <div class="mb-4 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm">
      {errorParam ?? loadError}
    </div>
  )}

  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold">Événements</h1>
    <a href="/hibou/event/nouveau/"
      class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors text-sm">
      + Créer un événement
    </a>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    {events.length === 0 && !loadError ? (
      <p class="text-gray-400 text-center py-12">Aucun événement.</p>
    ) : (
      <table class="w-full text-sm">
        <thead class="bg-gray-50 border-b border-gray-200">
          <tr>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Date</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Titre</th>
            <th class="text-left px-4 py-3 font-medium text-gray-600">Statut</th>
            <th class="text-right px-4 py-3 font-medium text-gray-600">Actions</th>
          </tr>
        </thead>
        <tbody>
          {events.map(e => (
            <tr class={`border-b border-gray-100 last:border-0 ${e.past ? 'opacity-50' : ''}`}>
              <td class="px-4 py-3 whitespace-nowrap tabular-nums">{fmt(e.date)}</td>
              <td class="px-4 py-3 font-medium">{e.title}</td>
              <td class="px-4 py-3">
                {e.draft
                  ? <span class="bg-yellow-100 text-yellow-800 text-xs font-medium px-2 py-0.5 rounded-full">Brouillon</span>
                  : e.past
                  ? <span class="bg-gray-100 text-gray-500 text-xs font-medium px-2 py-0.5 rounded-full">Passé</span>
                  : <span class="bg-green-100 text-green-800 text-xs font-medium px-2 py-0.5 rounded-full">Publié</span>
                }
              </td>
              <td class="px-4 py-3 text-right">
                <a href={`/hibou/event/${e.slug}/`} class="text-blue-600 hover:text-blue-800 font-medium mr-4">Modifier</a>
                <form method="POST" action="/api/hibou/delete-event/" class="inline"
                  onsubmit="return confirm('Supprimer définitivement cet événement ?')">
                  <input type="hidden" name="slug" value={e.slug} />
                  <button type="submit" class="text-red-500 hover:text-red-700 font-medium cursor-pointer">Supprimer</button>
                </form>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>
